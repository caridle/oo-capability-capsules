@startuml
left to right direction
actor "择偶者" as User
actor "审核员" as Reviewer
actor "支付网关" as Pay
actor "活体检测" as Liveness
actor "AI引擎" as AI

rectangle "缘识 AI婚恋平台" {
  usecase (UC-01 实名认证) as UC01
  usecase (UC-02 活体检测) as UC02
  usecase (UC-03 资料管理) as UC03
  usecase (UC-04 AI匹配推荐) as UC04
  usecase (UC-05 主动选择) as UC05
  usecase (UC-06 浏览推荐) as UC06
  usecase (UC-07 线上交流) as UC07
  usecase (UC-08 确认关系) as UC08
  usecase (UC-09 解封申请) as UC09
}

User --> UC01
User --> UC03
User --> UC06
UC01 ..> UC02 : <<include>>
UC05 ..> UC01 : <<include>>
UC07 ..> UC05 : <<include>>
UC08 ..> UC07 : <<include>>
UC04 ..> UC03 : <<extend>>
UC09 ..> UC08 : <<extend>>
UC02 --> Liveness
UC04 --> AI
UC05 --> Pay
Reviewer --> UC01
@enduml